# Put the real public backend URL here for frontend builds.
# Example Railway URL format: https://jobportal-production.up.railway.app
# These REACT_APP_* variables belong in Vercel for the React frontend.
REACT_APP_API_URL=https://your-railway-domain.up.railway.app
REACT_APP_SOCKET_URL=https://your-railway-domain.up.railway.app
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id
